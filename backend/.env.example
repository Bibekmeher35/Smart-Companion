# Backend Environment Variables

# Gemini API Key (Get from https://aistudio.google.com/)
GEMINI_API_KEY=your-gemini-api-key-here

# MongoDB Connection String
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/smart-companion

# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart-companion?retryWrites=true&w=majority

# JWT Secret (Change this to a random secure string!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-random-string

# Server Port (optional, defaults to 5050)
PORT=5050
